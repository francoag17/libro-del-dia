# --- API de Claude (resúmenes con IA) ---
# Conseguila en https://console.anthropic.com/  → API Keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Web Push (notificaciones) ---
# Generá las claves con:  npm run vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:francog@gmail.com

# --- App ---
PORT=3000
TZ_APP=America/Argentina/Buenos_Aires
# Horario del envío diario (formato cron). Por defecto 08:00.
DAILY_CRON=0 8 * * *
# Clave para proteger /api/run-daily cuando lo dispara un cron externo (dejala vacía en local).
CRON_SECRET=
